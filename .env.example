# Jira Configuration
JIRA_BASE_URL=https://your-instance.atlassian.net
JIRA_USERNAME=your-email@example.com
JIRA_API_TOKEN=your-jira-api-token
JIRA_PROJECT_KEY=PROJ
JIRA_UPDATE_SET_FIELD=customfield_10001

# ServiceNow Configuration
SN_INSTANCE_URL=https://your-instance.service-now.com
SN_USERNAME=your-servicenow-username
SN_PASSWORD=your-servicenow-password
SN_TABLE=sn_chg_management_update_set

# Agent Configuration
AGENT_NAME=Jira-ServiceNow Agent
LOG_LEVEL=INFO
RUN_INTERVAL_MINUTES=60
DRY_RUN=False

# State & Storage
STATE_FILE_PATH=./state/agent_state.json
LOG_FILE_PATH=./logs/agent.log
